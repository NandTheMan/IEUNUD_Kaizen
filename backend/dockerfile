# Use a lightweight Node.js 20 Alpine image
FROM node:20-alpine

# Set the working directory inside the container
WORKDIR /usr/src/app

# Install pnpm globally inside the container
RUN npm install -g pnpm

# Copy package.json and pnpm-lock.yaml first (for efficient caching)
COPY package.json pnpm-lock.yaml ./

# Install project dependencies
RUN pnpm install --frozen-lockfile

# Copy the rest of the application code (including Prisma schema)
COPY . .

# Generate Prisma Client (CRUCIAL: Must be done before the build step)
RUN npx prisma generate

# Build the NestJS application (Using the fast SWC compiler)
RUN pnpm run build

# Expose port 3001 (The port NestJS runs on)
EXPOSE 3001

# Apply any pending DB migrations, then start the server.
# This means whoever runs this container never has to type a prisma
# command by hand — new migrations you write just get applied on next restart.
CMD ["sh", "-c", "npx prisma migrate deploy && pnpm run start:prod"]