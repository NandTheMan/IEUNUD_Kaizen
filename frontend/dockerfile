# Use a lightweight Node.js 20 Alpine image
FROM node:20-alpine

# Set the working directory inside the container
WORKDIR /usr/src/app

# Install pnpm globally inside the container
RUN npm install -g pnpm

# Copy package.json and pnpm-lock.yaml first
COPY package.json pnpm-lock.yaml ./

# Install project dependencies
RUN pnpm install

# Copy all other source code components
COPY . .

# Build the Next.js application into static HTML/CSS/JS chunks
RUN pnpm run build

# Expose port 3000 (The port Next.js runs on)
EXPOSE 3000

# Start the Next.js production server
CMD [ "pnpm", "start" ]